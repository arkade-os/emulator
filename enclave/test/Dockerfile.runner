# QEMU-based test runner for the introspector enclave. Builds:
#   * vhost-device-vsock 0.3.0       (Rust)
#   * QEMU 9.2.4                     (C, x86_64-softmmu, h2c-compatible)
#   * enclave-cli + supervisor       (from the introspector-enclave additional context)
#   * grpc-client + mock-arkd        (from this repo)
#
# The build context is the introspector repo root. An additional context
# `introspector-enclave` points at the local working tree so the test
# exercises the in-development http2/gRPC framework changes.

# --- Stage 1: vhost-device-vsock ---
FROM rust:1.83-bookworm AS vsock-build
WORKDIR /src
RUN git clone --depth 1 --branch vhost-device-vsock-v0.3.0 \
      https://github.com/rust-vmm/vhost-device.git .
RUN cargo build --release -p vhost-device-vsock

# --- Stage 2: enclave-cli + supervisor (from introspector-enclave) ---
FROM golang:1.25-bookworm AS framework-build
WORKDIR /src
COPY --from=introspector-enclave go.mod go.sum ./
RUN go mod download
COPY --from=introspector-enclave . .
RUN CGO_ENABLED=0 go build -trimpath -o /enclave-cli ./cli/cmd/enclave
RUN CGO_ENABLED=0 go build -trimpath -o /supervisor ./supervisor/cmd/supervisor

# --- Stage 3: grpc-client + mock-arkd (test helpers) ---
FROM golang:1.26-bookworm AS test-helpers-build
WORKDIR /workspace

# Bring in both repos under predictable paths so the replace directives
# resolve. We rewrite the host paths in go.mod to the in-image paths.
COPY --from=introspector-enclave . /workspace/introspector-enclave/
COPY api-spec/ /workspace/introspector/api-spec/
COPY pkg/arkade/ /workspace/introspector/pkg/arkade/
COPY enclave/test/grpc-client/ /workspace/introspector/enclave/test/grpc-client/
COPY enclave/test/mock-arkd/ /workspace/introspector/enclave/test/mock-arkd/

# Rewrite the host-only replace directives so they point at the
# co-located paths inside the build stage.
RUN sed -i \
      -e 's|/home/joshua/introspector-enclave|/workspace/introspector-enclave|' \
      -e 's|/home/joshua/introspector/api-spec|/workspace/introspector/api-spec|' \
      -e 's|/home/joshua/introspector/pkg/arkade|/workspace/introspector/pkg/arkade|' \
      /workspace/introspector/enclave/test/grpc-client/go.mod

WORKDIR /workspace/introspector/enclave/test/grpc-client
RUN go mod tidy && CGO_ENABLED=0 go build -trimpath -o /grpc-client .

WORKDIR /workspace/introspector/enclave/test/mock-arkd
RUN go mod tidy && CGO_ENABLED=0 go build -trimpath -o /mock-arkd .

# --- Stage 4: QEMU 9.2.4 ---
FROM debian:bookworm AS qemu-build
RUN apt-get update && apt-get install -y \
      build-essential meson ninja-build pkg-config git \
      python3 python3-venv wget flex bison \
      libglib2.0-dev libpixman-1-dev libfdt-dev libcap-ng-dev \
      libslirp-dev liburing-dev \
      libcbor-dev libgnutls28-dev
RUN wget -q https://download.qemu.org/qemu-9.2.4.tar.xz \
    && tar xf qemu-9.2.4.tar.xz
WORKDIR /qemu-9.2.4
RUN ./configure \
      --target-list=x86_64-softmmu \
      --enable-kvm \
      --enable-vhost-user \
      --enable-gnutls
RUN make -j$(nproc)
RUN make DESTDIR=/qemu-install install

# --- Stage 5: runtime ---
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
      python3 curl jq ca-certificates procps psmisc unzip \
      libglib2.0-0 libpixman-1-0 libfdt1 libcap-ng0 \
      libslirp0 liburing2 \
      libcbor0.8 libgnutls30 \
      wget \
    && rm -rf /var/lib/apt/lists/*

RUN curl -sf "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscli.zip \
    && unzip -q /tmp/awscli.zip -d /tmp \
    && /tmp/aws/install \
    && rm -rf /tmp/awscli.zip /tmp/aws

RUN wget -qO- https://github.com/opentofu/opentofu/releases/download/v1.9.0/tofu_1.9.0_linux_amd64.tar.gz \
    | tar xz -C /usr/local/bin tofu

RUN wget -qO- https://github.com/fullstorydev/grpcurl/releases/download/v1.9.1/grpcurl_1.9.1_linux_x86_64.tar.gz \
    | tar xz -C /usr/local/bin grpcurl

COPY --from=vsock-build      /src/target/release/vhost-device-vsock /usr/local/bin/
COPY --from=framework-build  /enclave-cli  /usr/local/bin/enclave-cli
COPY --from=framework-build  /supervisor   /usr/local/bin/supervisor
COPY --from=test-helpers-build /grpc-client /usr/local/bin/grpc-client
COPY --from=test-helpers-build /mock-arkd   /usr/local/bin/mock-arkd
COPY --from=qemu-build       /qemu-install/usr/local/ /usr/local/

COPY --from=introspector-enclave test/heartbeat.py /usr/local/bin/heartbeat.py

WORKDIR /test
