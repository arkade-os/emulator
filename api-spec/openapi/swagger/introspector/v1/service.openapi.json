            "type": "string",
            "description": "A URL/resource name that uniquely identifies the type of the schema."
          }
        }
      },
      "GetInfoRequest": {
        "title": "GetInfoRequest",
        "type": "object"
      },
      "GetInfoResponse": {
        "title": "GetInfoResponse",
        "type": "object",
