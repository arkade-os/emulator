            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "signedIntent": {
            "$ref": "#/components/schemas/Intent"
          }
        }
      },
      "SubmitFinalizationResponse": {
        "title": "SubmitFinalizationResponse",
        "type": "object",
        "properties": {
          "signedCommitmentTx": {
            "type": "string"
          },
          "signedForfeits": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SubmitIntentRequest": {
        "title": "SubmitIntentRequest",
        "type": "object",
        "properties": {
          "intent": {
            "$ref": "#/components/schemas/Intent"
          }
        }
      },
      "SubmitIntentResponse": {
        "title": "SubmitIntentResponse",
        "type": "object",
        "properties": {
          "signedProof": {
            "type": "string"
          }
        }
      },
      "SubmitOnchainTxRequest": {
        "title": "SubmitOnchainTxRequest",
        "type": "object",
        "properties": {
          "tx": {
            "type": "string",
            "description": "base64 psbt"
          }
        }
      },
      "SubmitOnchainTxResponse": {
        "title": "SubmitOnchainTxResponse",
        "type": "object",
        "properties": {
          "signedTx": {
            "type": "string"
          }
        }
      },
      "SubmitTxRequest": {
        "title": "SubmitTxRequest",
        "type": "object",
        "properties": {
          "arkTx": {
            "type": "string",
            "description": "base64 psbt"
          },
          "checkpointTxs": {
            "type": "array",
            "description": "base64 psbts",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "SubmitTxResponse": {
        "title": "SubmitTxResponse",
        "type": "object",
        "properties": {
          "signedArkTx": {
            "type": "string"
          },
          "signedCheckpointTxs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "TxTreeNode": {
        "title": "TxTreeNode",
        "type": "object",
        "properties": {
          "children": {
            "type": "object",
